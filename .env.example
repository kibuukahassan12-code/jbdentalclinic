# Server
PORT=3001
NODE_ENV=development

# Admin API key / JWT secret (required for all /api/* admin routes)
ADMIN_API_KEY=your-secret-api-key
# Admin login (auto-created on server start if not in DB)
ADMIN_EMAIL=admin@jbdentalclinic.com
ADMIN_PASSWORD="@Admin123#"

# Database (optional; default: ./data/appointments.db)
# DATABASE_PATH=./data/appointments.db

# WhatsApp Cloud API (Meta)
# Get these from developers.facebook.com -> your app -> WhatsApp -> API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Reminder cron: default every 30 minutes (*/30 * * * *)
# This enables: thank you messages, 1-day, 6-hour, and 1-hour reminders
# REMINDER_CRON=*/30 * * * *
# TZ=Africa/Kampala

# Clinic phone number for WhatsApp links (frontend)
# VITE_CLINIC_PHONE=256752001269

# CORS (production): your frontend origin
# CORS_ORIGIN=https://jbdental.ug
