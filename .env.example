# Server
PORT=3001
NODE_ENV=development

# Admin API key / JWT secret (required for all /api/* admin routes)
ADMIN_API_KEY=your-secret-api-key
# Admin login (auto-created on server start if not in DB)
ADMIN_EMAIL=admin@jbdentalclinic.com
ADMIN_PASSWORD="@Admin123#"

# Database path (IMPORTANT for production: set to a persistent volume path)
# Local dev default: ./data/appointments.db
# Koyeb production (persistent volume mounted at /app/data):
# DATABASE_PATH=/app/data/appointments.db

# WhatsApp Cloud API (Meta)
# Get these from developers.facebook.com -> your app -> WhatsApp -> API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp approved templates (recommended for production deliverability)
# Configure these to match your approved template names in Meta Business Manager.
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_TEMPLATE_THANK_YOU=jb_thank_you
WHATSAPP_TEMPLATE_1DAY=jb_reminder_1day
WHATSAPP_TEMPLATE_6H=jb_reminder_6h
WHATSAPP_TEMPLATE_1H=jb_reminder_1h

# Email reminders (SMTP)
EMAIL_FROM=JB Dental Clinic <info@jbdental.ug>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Reminder cron: default every 30 minutes (*/30 * * * *)
# This enables: thank you messages, 1-day, 6-hour, and 1-hour reminders
# REMINDER_CRON=*/30 * * * *
# TZ=Africa/Kampala

# Clinic phone number for WhatsApp links (frontend)
# VITE_CLINIC_PHONE=256752001269

# CORS (production): your frontend origin
# CORS_ORIGIN=https://jbdental.ug
